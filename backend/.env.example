# ========================================
# Prompt2Frame Backend Configuration
# ========================================

# ---------------------------------------
# Required: API Keys
# ---------------------------------------

# Groq API Key (REQUIRED)
# Get your API key from: https://console.groq.com/keys
# This is used for LLM-based prompt expansion and code generation
GROQ_API_KEY=your_groq_api_key_here

# ---------------------------------------
# Server Configuration
# ---------------------------------------

# Port the backend server will run on
# Default: 5000 for local development
# Railway/Render will override this with their own $PORT
PORT=5000

# Enable debug mode (adds verbose logging)
# Set to 'false' in production
DEBUG=false

# ---------------------------------------
# Security: CORS Configuration
# ---------------------------------------

# Comma-separated list of allowed origins
# Development: Include your local frontend URL
# Production: Add your deployed frontend domain
# Example: http://localhost:5173,https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173

# ---------------------------------------
# Optional: Performance Tuning
# ---------------------------------------

# Maximum number of concurrent render requests
# Default: 2 (recommended for free-tier deployments)
MAX_CONCURRENT_REQUESTS=2

# Request timeout in seconds
# Default: 300 (5 minutes)
REQUEST_TIMEOUT=300

# ---------------------------------------
# Optional: File System
# ---------------------------------------

# Video cleanup age in hours
# Videos older than this will be deleted automatically
# Default: 24 hours
VIDEO_CLEANUP_AGE_HOURS=24

# Maximum total video storage in GB
# Cleanup triggers when exceeded
# Default: 5 GB
MAX_VIDEO_STORAGE_GB=5

# ---------------------------------------
# Optional: HF Spaces / Render Performance
# ---------------------------------------

# Hard cap on Manim subprocess runtime in seconds.
# HF free-tier CPUs OOM-kill processes silently after ~2 min.
# Default: 120 (recommended for HF free tier)
# Increase to 240 if running on a paid instance with more CPU.
MANIM_TIMEOUT_SECONDS=120

# Force all renders to use -ql (480p, 15fps) to reduce CPU usage.
# Strongly recommended for HF Spaces free tier.
# Set to "0" on paid instances that can handle -qm.
FORCE_LOW_QUALITY=1
