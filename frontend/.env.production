# Frontend Production Environment Variables

# Backend API URL — your deployed HF Space backend
# Format: https://<username>-<space-name>.hf.space
# Do NOT include a trailing slash.
VITE_BACKEND_URL=https://sourize-prompt2frame-backend.hf.space

# HF Token — only needed if the backend Space is set to Private.
# Leave blank if the Space is Public (recommended for open demos).
# VITE_HF_TOKEN=hf_...
